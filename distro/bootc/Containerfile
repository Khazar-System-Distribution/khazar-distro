# KhazarOS — Fedora Silverblue-based AI Desktop
# Build:  podman build -t khazaros .
# Deploy: bootc switch khazaros

FROM quay.io/fedora/fedora-bootc:40

# ── Khazar user ──────────────────────────────────────
RUN groupadd -r khazar && useradd -r -s /sbin/nologin -d /var/lib/khazar -g khazar khazar
RUN mkdir -p /var/lib/khazar/{bin,models,run} && chown -R khazar:khazar /var/lib/khazar

# ── Build dependencies ───────────────────────────────
RUN rpm-ostree install --apply-live \
    gcc make git socat python3 \
    nmcli NetworkManager-wifi \
    pulseaudio-utils \
    gnome-shell-extension-tool

# ── Khazar platform ──────────────────────────────────
COPY . /tmp/khazar-build
WORKDIR /tmp/khazar-build
RUN make all PREFIX=/var/lib/khazar
RUN make install DESTDIR=/ DESTDIR=/ PREFIX=/var/lib/khazar \
    || (mkdir -p /var/lib/khazar/bin && \
        cp components/orchestrator/ai-orchestrator /var/lib/khazar/bin/ && \
        cp components/rule-engine/ai-rule-engine /var/lib/khazar/bin/ && \
        cp components/policy-engine/ai-policy-engine /var/lib/khazar/bin/ && \
        cp components/model-runtime/ai-model-runtime /var/lib/khazar/bin/ && \
        cp components/intent-classifier/ai-intent-classifier /var/lib/khazar/bin/ && \
        cp agents/desktop-agent/ai-desktop-agent /var/lib/khazar/bin/ && \
        cp agents/package-agent/ai-package-agent /var/lib/khazar/bin/ && \
        cp agents/network-agent/ai-network-agent /var/lib/khazar/bin/ && \
        cp agents/power-agent/ai-power-agent /var/lib/khazar/bin/ && \
        cp agents/audio-agent/ai-audio-agent /var/lib/khazar/bin/)

# ── Configs ──────────────────────────────────────────
COPY distro/configs /etc/khazar
RUN chown -R khazar:khazar /etc/khazar

# ── CLI ───────────────────────────────────────────────
COPY distro/cli/kha /usr/bin/kha
RUN chmod +x /usr/bin/kha

# ── systemd daemons ──────────────────────────────────
COPY distro/systemd/*.service /etc/systemd/system/
COPY distro/systemd/khazar.target /etc/systemd/system/
RUN systemctl enable khazar.target
RUN systemctl enable ai-rule-engine.service
RUN systemctl enable ai-policy-engine.service
RUN systemctl enable ai-orchestrator.service
RUN systemctl enable ai-desktop-agent.service
RUN systemctl enable ai-package-agent.service
RUN systemctl enable ai-network-agent.service
RUN systemctl enable ai-power-agent.service
RUN systemctl enable ai-audio-agent.service

# ── GNOME Extension ──────────────────────────────────
COPY distro/gnome-extension /usr/share/gnome-shell/extensions/khazar@devuan.kg

# ── Branding ─────────────────────────────────────────
COPY distro/branding/khazar-logo.svg /usr/share/icons/hicolor/scalable/apps/
COPY distro/branding/khazar-wallpaper.png /usr/share/backgrounds/

# ── First-boot wizard ────────────────────────────────
COPY distro/installer/khazar-welcome.desktop /etc/xdg/autostart/
COPY distro/installer/khazar-welcome /usr/bin/khazar-welcome
RUN chmod +x /usr/bin/khazar-welcome

# ── Cleanup ──────────────────────────────────────────
RUN rm -rf /tmp/khazar-build
RUN rpm-ostree cleanup -m

# ── Metadata ─────────────────────────────────────────
LABEL distro.name="KhazarOS"
LABEL distro.version="0.1.0"
LABEL distro.family="Fedora Silverblue"
LABEL distro.description="AI-powered desktop operating system"
LABEL distro.homepage="https://github.com/Khazar-System-Distribution/khazar"

CMD ["/sbin/init"]
